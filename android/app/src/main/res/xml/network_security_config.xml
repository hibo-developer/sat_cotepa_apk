<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Bloquea trafico cleartext (HTTP) por defecto en toda la app -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Dominios a los que la app se conecta: solo HTTPS -->
    <domain-config cleartextTrafficPermitted="false">
        <domain includeSubdomains="true">supabase.co</domain>
        <domain includeSubdomains="true">pwnedpasswords.com</domain>
        <domain includeSubdomains="true">resend.com</domain>
    </domain-config>
</network-security-config>
