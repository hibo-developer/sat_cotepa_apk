{
  "name": "app-sat",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:pwsh": "powershell -ExecutionPolicy Bypass -File ./scripts/dev.ps1",
    "build": "vite build",
    "build:pwsh": "powershell -ExecutionPolicy Bypass -File ./scripts/build.ps1",
    "preflight:prod:pwsh": "powershell -ExecutionPolicy Bypass -File ./scripts/preflight-production.ps1",
    "release:check:pwsh": "npm run build:pwsh && npm run preflight:prod:pwsh",
    "build:apk:pwsh": "powershell -ExecutionPolicy Bypass -File ./scripts/build-apk.ps1",
    "build:desktop:pwsh": "powershell -ExecutionPolicy Bypass -File ./scripts/build-desktop.ps1",
    "build:desktop:portable:pwsh": "powershell -ExecutionPolicy Bypass -File ./scripts/build-desktop.ps1 -Target portable",
    "preview": "vite preview",
    "desktop:dev": "concurrently \"npm:dev\" \"wait-on tcp:5173 && electron .\"",
    "desktop:start": "npm run build && electron .",
    "desktop:build:win": "powershell -ExecutionPolicy Bypass -File ./scripts/build-desktop.ps1",
    "desktop:build:portable": "powershell -ExecutionPolicy Bypass -File ./scripts/build-desktop.ps1 -Target portable"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.1",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@supabase/supabase-js": "^2.49.8",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.511.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "postcss": "^8.4.49",
    "supabase": "^2.95.0",
    "tailwindcss": "^3.4.16",
    "vite": "^8.0.9",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.cotepa.sat.desktop",
    "productName": "SAT Movil COTEPA",
    "artifactName": "SAT-Movil-COTEPA-Setup-${version}-${arch}.${ext}",
    "afterPack": "electron/afterPack.cjs",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release-desktop"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "electron/assets/app-icon.ico",
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "electron/assets/app-icon.ico",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "SAT Movil COTEPA"
    }
  }
}
